{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "bash build.sh",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["pkgs.python313", "pkgs.pkg-config", "pkgs.libmysqlclient"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "gunicorn fir_system.wsgi:application --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
