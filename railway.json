{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "providers": ["python"]
    },
    "watch": ["backend"],
    "buildCommand": "cd backend && bash build.sh"
  },
  "deploy": {
    "startCommand": "cd backend && gunicorn fir_system.wsgi:application --bind 0.0.0.0:$PORT",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}
